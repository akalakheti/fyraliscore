# Copy this file to `.env` and fill in the secrets. Never commit `.env`.
# `.env` is gitignored; only `.env.example` should ever be tracked.
#
# A second-tier overlay file `.env.dogfood` is also gitignored and is
# loaded on top of `.env` by scripts/dogfood_up.sh. Both files are
# templated below — split values into the file that fits.

# =====================================================================
# Core: Postgres + Ollama
# =====================================================================

# Local Postgres (pgvector). Brought up by `docker compose up -d postgres`.
DATABASE_URL=postgresql://company_os:company_os@localhost:5432/company_os

# Local Ollama for embeddings. Brought up by `docker compose up -d ollama`,
# or run natively via `ollama serve`.
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# =====================================================================
# LLM provider
# =====================================================================
# One of: anthropic | openai | deepseek
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=30

# Provider keys. Only the one matching LLM_PROVIDER is required.
# Generic fallback (used when the provider-specific key is unset).
LLM_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Optional: raise the per-call ceiling for slow real-LLM runs (ms).
# LLM_TIMEOUT_OVERRIDE_MS=120000

# =====================================================================
# Tenant / actor identity
# =====================================================================
# Default tenant for local dev. Production is multi-tenant; do not rely
# on this in non-dev environments.
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
COMPANY_OS_TENANT_ID=00000000-0000-0000-0000-000000000001
COMPANY_OS_CEO_ACTOR_ID=00000000-0000-0000-0000-000000000002
SIMULATION_TENANT_ID=00000000-0000-0000-0000-000000000001

# =====================================================================
# Gateway runtime
# =====================================================================
# Accepted values: dev | staging | test. Enables synthetic-bypass
# guard, sim mount default, and dev-mode middleware shortcuts.
COMPANY_OS_ENV=dev

GATEWAY_PORT=8000
# 1 = the gateway uvicorn process owns the asyncpg pool and closes it
# on shutdown. Tests inject their own pool, so they set this to 0.
GATEWAY_OWNS_POOL=1
GATEWAY_START_GRT_SCHEDULER=1
GATEWAY_MOUNT_SIM=1
GATEWAY_CEO_VIEW_ENABLED=1

# CEO view personalisation
VIEW_CEO_DISPLAY_NAME=Rachin
VIEW_CEO_TIMEZONE=Asia/Kathmandu
# Deterministic bearer token so the UI can authenticate without a
# /auth/session round-trip. Keep this off in any shared environment.
DEV_BEARER_TOKEN=dogfood-ceo-token
VIEW_CEO_TOKEN=ceo-dogfood-token

# In-process scheduler / rendering adapters point at the gateway itself
# under the single-port topology used in dev.
GRT_RENDERING_BASE_URL=http://127.0.0.1:8000
QUERY_RENDERING_BASE_URL=http://127.0.0.1:8000
# QUERY_RENDERING_AUTH_TOKEN=
# Cache backend for the query-side rendering adapter: memory | pg.
QUERY_CACHE_BACKEND=pg

# =====================================================================
# Workers
# =====================================================================
THINK_WORKER_POLL_INTERVAL_S=2
POST_COMMIT_WORKER_POLL_INTERVAL_S=5
# How often the greeting refreshes when the dashboard is open (seconds).
GREETING_REFRESH_INTERVAL_SECONDS=900

# =====================================================================
# Ingestion: Slack signature verification
# =====================================================================
# HMAC secret used to verify POST /ingest/slack:message signatures.
# Leave blank in dev to skip verification.
SLACK_SIGNING_SECRET=

# =====================================================================
# Auth bootstrap
# =====================================================================
# REQUIRED IN PRODUCTION. When set, POST /auth/session requires the
# X-Bootstrap-Secret header to match this value. When unset in a prod
# environment (COMPANY_OS_ENV=prod), the endpoint returns 503 and
# session minting is fully blocked.
# In dev (COMPANY_OS_ENV=dev), leaving this blank skips the check.
#
# Generate a value with: openssl rand -hex 32
AUTH_BOOTSTRAP_SECRET=

# =====================================================================
# Nexus (AI agent attestation) — stubbed in Phase 0–3
# =====================================================================
NEXUS_URL=http://localhost:8090
NEXUS_API_KEY=

# =====================================================================
# Observability / debug
# =====================================================================
LOG_LEVEL=INFO
# Gates think_run_artifacts capture and the /debug/* endpoints. Dev only.
DEBUG_ARTIFACT_CAPTURE=1
