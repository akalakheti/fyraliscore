# Path-based routing overrides for demo.fyralis.xyz.
# Included inside the nginx server block generated by nginx-proxy.
# The ui container handles everything else (SPA static files).

# FastAPI gateway — /api/ prefix (Vite proxy strips /api before forwarding)
location /api/ {
    proxy_pass http://gateway:8000/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}

# FastAPI gateway — /v1/ routes (card conversations, demo sessions, etc.)
location /v1/ {
    proxy_pass http://gateway:8000/v1/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}

# WebSocket stream — strips /stream/ prefix
location /stream/ {
    proxy_pass http://gateway:8000/;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_read_timeout 86400s;
}

# Health check
location /healthz {
    proxy_pass http://gateway:8000/healthz;
}
